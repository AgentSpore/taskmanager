# TaskManager Environment Configuration
# Copy this file to .env and update with your values

# Application Settings
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here-change-in-production
APP_NAME=TaskManager
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=sqlite:///./taskmanager.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/taskmanager
# For MySQL: DATABASE_URL=mysql://user:password@localhost:3306/taskmanager

# Database Settings
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis Settings
REDIS_MAX_CONNECTIONS=100
REDIS_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Third-party Services
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# AI Service Configuration
AI_ENABLED=true
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
AI_TOP_P=1.0
AI_FREQUENCY_PENALTY=0.0
AI_PRESENCE_PENALTY=0.0

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
FROM_EMAIL=your-email@gmail.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/taskmanager.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=10

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Security Configuration
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_LIMIT=5
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_TIME=300

# Session Configuration
SESSION_SECRET=your-session-secret-here-change-in-production
SESSION_LIFETIME=1800
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=lax

# Monitoring and Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/api/health

# Performance Configuration
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000
CACHE_KEY_PREFIX=tm_

# Task Management Settings
DEFAULT_TASK_PRIORITY=medium
DEFAULT_TASK_STATUS=pending
TASK_MAX_TITLE_LENGTH=200
TASK_MAX_DESCRIPTION_LENGTH=2000
TASK_MAX_TAGS=10
TASK_MAX_SUBTASKS=50
TASK_SCHEDULING_ENABLED=true
TASK_REMINDERS_ENABLED=true
TASK_REMINDER_HOURS=24

# Team Management Settings
TEAM_MAX_MEMBERS=50
TEAM_MAX_PROJECTS=10
INVITE_EXPIRE_HOURS=24
PERMISSION_LEVELS=read,write,admin

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=365
ANALYTICS_INTERVAL_MINUTES=60
ANALYTICS_BATCH_SIZE=100

# Third-party Integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Development Settings (development mode only)
DEV_AUTO_MIGRATE=true
DEV_DEBUG_TOOLBAR=false
DEV_SHOW_SQL=false
DEV_SENTRY_DSN=
DEV_NEW_RELIC_LICENSE_KEY=

# Production Settings
PRODUCTION_DSN=
NEW_RELIC_LICENSE_KEY=
SENTRY_DSN=
GRAFANA_URL=https://grafana.example.com
PROMETHEUS_URL=https://prometheus.example.com

# Testing Configuration
TEST_DATABASE_URL=sqlite:///./test_taskmanager.db
TEST_DATABASE_ECHO=false
TEST_REDIS_URL=redis://localhost:6379/1
TEST_SECRET_KEY=test-secret-key-only

# Docker Configuration
DOCKER_HOST=docker
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=taskmanager
DOCKER_IMAGE_TAG=latest

# CI/CD Configuration
CI_BRANCH=main
CI_COMMIT_SHA=
CI_BUILD_NUMBER=
CI_BUILD_URL=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups
BACKUP_COMPRESSION=true

# Maintenance Configuration
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System maintenance in progress. Please check back later.
MAINTENANCE_START_TIME=
MAINTENANCE_END_TIME=

# Feature Flags
FEATURE_AI_SUGGESTIONS=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_TASK_DEPENDENCIES=true
FEATURE_TIME_TRACKING=true
FEATURE_REPORTS=true
FEATURE_IMPORT_EXPORT=true
FEATURE_API_KEY_AUTH=true
FEATURE_SOCIAL_LOGIN=false

# API Configuration
API_VERSION=v1
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=3600
API_KEY_HEADER=X-API-Key
API_AUTH_HEADER=Authorization

# Webhook Configuration
WEBHOOK_ENABLED=true
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_MAX_RETRIES=3
WEBHOOK_TIMEOUT=30
WEBHOOK_EVENTS=task_created,task_updated,task_deleted

# File Storage Configuration
STORAGE_TYPE=local
STORAGE_BUCKET_NAME=taskmanager-uploads
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT_URL=

# Search Configuration
SEARCH_ENGINE=elasticsearch
SEARCH_HOST=localhost
SEARCH_PORT=9200
SEARCH_INDEX_PREFIX=taskmanager
SEARCH_TIMEOUT=10
SEARCH_MAX_RESULTS=100

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_EMAIL=true
NOTIFICATION_PUSH=true
NOTIFICATION_SMS=false
NOTIFICATION_WEBHOOK=true

# Cache Configuration
CACHE_TYPE=redis
CACHE_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=tm_cache_
CACHE_DEFAULT_TIMEOUT=300

# External Services Configuration
EXTERNAL_SERVICE_TIMEOUT=30
EXTERNAL_SERVICE_RETRIES=3
EXTERNAL_SERVICE_BACKOFF_FACTOR=2

# Performance Monitoring
PERFORMANCE_ENABLED=true
PERFORMANCE_SAMPLE_RATE=0.1
PERFORMANCE_TRANSACTION_NAMES_ENABLED=true
PERFORMANCE_TRANSACTION_NAMES_MAX_LENGTH=100

# Security Headers
SECURITY_FRAME_OPTIONS=DENY
SECURITY_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_XSS_PROTECTION=1; mode=block
SECURITY_STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains

# Compliance
GDPR_ENABLED=true
GDPR_DATA_RETENTION_DAYS=365
GDPR_RIGHT_TO_FORGET=true
GDPR_RIGHT_TO_ACCESS=true

# Internationalization
I18N_ENABLED=true
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,fr,de,ja,ko,zh
TIMEZONE=UTC

# Analytics and Tracking
ANALYTICS_PROVIDER=google_analytics
ANALYTICS_ID=UA-XXXXXXXXX-X
ANALYTICS_ANONYMIZE_IP=true
ANALYTICS_COOKIES_ENABLED=true

# Social Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Payment Configuration (for premium features)
PAYMENT_STRIPE_PUBLISHABLE_KEY=pk_test_
PAYMENT_STRIPE_SECRET_KEY=sk_test_
PAYMENT_WEBHOOK_SECRET=whsec_

# Support Configuration
SUPPORT_EMAIL=support@taskmanager.com
SUPPORT_PHONE=+1-555-123-4567
SUPPORT_HOURS=Monday-Friday 9am-6pm EST

# Legal
PRIVACY_POLICY_URL=https://yourdomain.com/privacy
TERMS_OF_SERVICE_URL=https://yourdomain.com/terms
CONTACT_EMAIL=contact@yourdomain.com

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_FALLBACK=true

# Performance Optimization
CORS_ENABLED=true
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# Session Management
SESSION_STORE=redis
SESSION_TIMEOUT=1800
SESSION_REFRESH_INTERVAL=300
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAMESITE=lax

# Database Pooling
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Connection Pool Settings
CONNECTION_POOL_SIZE=10
CONNECTION_POOL_TIMEOUT=30
CONNECTION_POOL_MAX_RETRIES=3
CONNECTION_POOL_RETRY_DELAY=1

# Security Settings
SECURITY_PASSWORD_HASH=bcrypt
SECURITY_PASSWORD_SALT_ROUNDS=12
SECURITY_TOKEN_EXPIRY=3600
SECURITY_REFRESH_TOKEN_EXPIRY=604800
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_PER_MINUTE=100

# File Upload Security
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain
UPLOAD_DISALLOWED_EXTENSIONS=exe,php,sh,bat,cmd
UPLOAD_SCAN_VIRUSES=false
UPLOAD_SANITIZE_FILENAME=true

# Email Configuration
SMTP_TIMEOUT=30
SMTP_USE_SSL=false
SMTP_FROM_NAME=TaskManager
SMTP_REPLY_TO=support@taskmanager.com
EMAIL_TEMPLATE_DIR=templates/email
EMAIL_QUEUE_SIZE=100
EMAIL_WORKERS=4

# Cache Settings
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=tm_cache_
CACHE_MAX_ENTRIES=1000
CACHE_ENTRY_VERSION=1
CACHE_COMPRESSION=true

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/taskmanager.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_ROTATE=true

# Monitoring Settings
MONITORING_ENABLED=true
MONITORING_INTERVAL=60
MONITORING_RETENTION_DAYS=30
MONITORING_ALERTS_ENABLED=true
MONITORING_ALERTS_EMAIL=support@taskmanager.com

# Feature Toggle Settings
FEATURE_TOGGLE_ENABLED=true
FEATURE_TOGGLE_API=true
FEATURE_TOGGLE_ADMIN=true
FEATURE_TOGGLE_USER=true
FEATURE_TOGGLE_ANONYMOUS_ACCESS=false

# API Settings
API_VERSION=v1
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=3600
API_KEY_HEADER=X-API-Key
API_AUTH_HEADER=Authorization
API_CORS_ENABLED=true
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_SWAGGER_ENABLED=true
API_SWAGGER_UI=true

# Testing Settings
TEST_DATABASE_URL=sqlite:///./test_taskmanager.db
TEST_DATABASE_ECHO=false
TEST_REDIS_URL=redis://localhost:6379/1
TEST_SECRET_KEY=test-secret-key-only
TEST_DEBUG=false
TEST_COVERAGE_ENABLED=true
TEST_COVERAGE_THRESHOLD=80

# Development Settings
DEBUG_TOOLBAR_ENABLED=false
DEBUG_TOOLBAR_PANELS=true
DEBUG_TOOLBAR_SHOW_TOOLBAR_ON_GET=true
DEBUG_TOOLBAR_SHOW_TOOLBAR_ON_POST=true
DEBUG_TOOLBAR_CONFIG={
    "SHOW_TOOLBAR": true,
    "RENDER_PANELS": true,
    "SHOW_SQL": true,
    "SHOW_TEMPLATE_TIMING": true
}

# Production Settings
PRODUCTION_DEBUG=false
PRODUCTION_SENTRY_DSN=
PRODUCTION_NEW_RELIC_LICENSE_KEY=
PRODUCTION_GRAVATAR_ENABLED=true
PRODUCTION_GRAVATAR_DEFAULT=identicon
PRODUCTION_GRAVATAR_SIZE=100
PRODUCTION_GRAVATAR_RATING=g
PRODUCTION_GRAVATAR_FORCE_default=false