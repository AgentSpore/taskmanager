# TaskManager Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Basic Application Settings
# =============================================================================

# Application name (used in logging and headers)
APP_NAME=TaskManager

# Application version
APP_VERSION=0.1.0

# Application description
APP_DESCRIPTION=AI-powered task management system

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind the server to
HOST=0.0.0.0

# Port to run the server on
PORT=8000

# Enable auto-reload for development (true/false)
RELOAD=true

# =============================================================================
# Database Configuration
# =============================================================================

# Database URL
# For development: sqlite:///./taskmanager.db
# For PostgreSQL: postgresql://user:password@localhost/taskmanager
# For production: postgresql://user:password@db:5432/taskmanager
DATABASE_URL=sqlite:///./taskmanager.db

# Database connection pool size
DATABASE_POOL_SIZE=5

# Database maximum overflow connections
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated for multiple)
# Use * for development, specify specific domains for production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Allow credentials (true/false)
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods (comma-separated)
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers (comma-separated)
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, leave empty for console logging)
LOG_FILE=

# =============================================================================
# AI/ML Configuration
# =============================================================================

# OpenAI API key (required for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use
OPENAI_MODEL=gpt-3.5-turbo

# Enable AI features (true/false)
AI_ENABLED=true

# =============================================================================
# Security Configuration
# =============================================================================

# Secret key for JWT tokens and session management
# Generate a new secret key for production!
SECRET_KEY=your-secret-key-change-in-production-please-use-a-long-random-string

# JWT algorithm
ALGORITHM=HS256

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# Rate Limiting
# =============================================================================

# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Number of requests allowed per window
RATE_LIMIT_REQUESTS=100

# Rate limiting window in seconds
RATE_LIMIT_WINDOW=60

# =============================================================================
# Task Management Defaults
# =============================================================================

# Default priority for new tasks
DEFAULT_PRIORITY=medium

# Default status for new tasks
DEFAULT_STATUS=pending

# Default due date in days from creation
DEFAULT_DUE_DAYS=7

# =============================================================================
# Analytics Configuration
# =============================================================================

# Enable analytics collection (true/false)
ANALYTICS_ENABLED=true

# Analytics data retention period in days
ANALYTICS_RETENTION_DAYS=365

# =============================================================================
# Email Configuration
# =============================================================================

# Enable email notifications (true/false)
EMAIL_ENABLED=false

# SMTP server hostname
SMTP_SERVER=smtp.gmail.com

# SMTP server port
SMTP_PORT=587

# SMTP username
SMTP_USERNAME=your-email@gmail.com

# SMTP password (or app password)
SMTP_PASSWORD=your-app-password

# From email address
EMAIL_FROM=your-email@gmail.com

# =============================================================================
# Task AI Configuration
# =============================================================================

# Enable AI-powered task features (true/false)
TASK_AI_ENABLED=true

# Number of AI suggestions to generate
TASK_AI_SUGGESTIONS_COUNT=5

# Maximum length for AI task descriptions
TASK_AI_MAX_LENGTH=1000

# =============================================================================
# File Upload Configuration
# =============================================================================

# Enable file uploads (true/false)
FILE_UPLOAD_ENABLED=false

# Maximum file upload size in bytes (default: 10MB = 10485760)
FILE_UPLOAD_MAX_SIZE=10485760

# Allowed file types (comma-separated)
FILE_UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,txt,doc,docx

# =============================================================================
# Development Settings
# =============================================================================

# Development-specific settings
# These are validated automatically but can be customized here

# Development database URL
DATABASE_URL_DEV=sqlite:///./dev_taskmanager.db

# Development log level
LOG_LEVEL_DEV=DEBUG

# Development CORS origins
CORS_ORIGINS_DEV=http://localhost:3000,http://localhost:8080,http://localhost:5173

# =============================================================================
# Production Settings
# =============================================================================

# Production settings - use these when ENVIRONMENT=production

# Production database URL
DATABASE_URL_PROD=postgresql://taskmanager:secure-password@db:5432/taskmanager

# Production secret key (generate a new one!)
SECRET_KEY_PROD=your-very-secure-production-secret-key-here

# Production log level
LOG_LEVEL_PROD=INFO

# Production CORS origins
CORS_ORIGINS_PROD=https://yourdomain.com,https://api.yourdomain.com

# =============================================================================
# Optional Third-Party Services
# =============================================================================

# Redis configuration (optional, for caching and session management)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery configuration (optional, for background tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Monitoring and logging
SENTRY_DSN=your-sentry-dsn-here
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090

# =============================================================================
# Docker Configuration
# =============================================================================

# Docker-specific settings
DOCKER_ENV=true
DOCKER_HOST=localhost
DOCKER_PORT=2376

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable specific features
ENABLE_TELEMETRY=false
ENABLE_FEATURE_FLAGGING=false
ENABLE_A_B_TESTING=false
ENABLE_WEBHOOKS=false
ENABLE_WEB_SOCKETS=true
ENABLE_CACHING=true
ENABLE_COMPRESSION=true

# =============================================================================
# Performance Optimization
# =============================================================================

# Cache configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_CLEANUP_INTERVAL=300

# Database optimization
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# API optimization
API_TIMEOUT=30
API_MAX_CONNECTIONS=100
API_KEEP_ALIVE=5