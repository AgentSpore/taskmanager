# Production environment configuration for TaskManager

ENVIRONMENT=production
DEBUG=false
RELOAD=false
LOG_LEVEL=INFO

# Database (PostgreSQL recommended)
DATABASE_URL=postgresql://taskmanager:your-secure-password@db:5432/taskmanager

# Server
HOST=0.0.0.0
PORT=8000

# Security - Generate strong secrets for production!
SECRET_KEY=your-ultra-secure-secret-key-here-should-be-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Features
OPENAI_API_KEY=your-production-openai-api-key
AI_ENABLED=true
TASK_AI_ENABLED=true

# CORS - Restrict to specific domains in production
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Task defaults
DEFAULT_PRIORITY=medium
DEFAULT_STATUS=pending
DEFAULT_DUE_DAYS=7

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=365

# Email (configure with your SMTP settings)
EMAIL_ENABLED=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# File uploads
FILE_UPLOAD_ENABLED=true
FILE_UPLOAD_MAX_SIZE=10485760
FILE_UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,doc,docx

# Production features
ENABLE_METRICS=true
SWAGGER_ENABLED=false
REDOC_ENABLED=false
ENABLE_QUERY_LOGGING=false
ENABLE_PERFORMANCE_MONITORING=true

# Monitoring
HEALTH_CHECK_PATH=/api/health
METRICS_PORT=8080

# Additional production settings
ENABLE_COMPRESSION=true
ENABLE_RATE_LIMITING_BY_IP=true
ENABLE_REQUEST_LOGGING=true
ENABLE_AUDIT_LOGGING=true
LOG_RETENTION_DAYS=30
ENABLE_BACKUPS=true